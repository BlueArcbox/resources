        "MessageId": 101310141,
        "Flag": 2,
        "Type": 0,
        "NextId": -1,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "はい、ありがとうございます！",
        "MessageKR": "네! 감사합니다!",
        "MessageTW": "好的！謝謝您！",
        "MessageEN": "Excellent! Thank you!"
