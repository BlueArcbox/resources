        "MessageEN": "That's what I meant. Thank you."
    },
    {
        "MessageId": 200520381,
        "Flag": 2,
        "Type": 0,
        "NextId": 200520390,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "結論を明瞭に伝えるその話法",
