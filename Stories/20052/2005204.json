    {
        "MessageId": 200520471,
        "Flag": 2,
        "Type": 0,
        "NextId": 200520480,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "それ以外でも",
        "MessageKR": "아니면 그냥이든요",
        "MessageTW": "也可能沒什麼理由",
        "MessageEN": "...or simply for the sake of it."
    },
    {
        "MessageId": 200520480,
        "Flag": 2,
        "Type": 3,
        "NextId": 200520490,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "いつでも遊びにきてね",
        "MessageKR": "언제든 와도 돼.",
        "MessageTW": "隨時都歡迎你來哦",
        "MessageEN": "Drop by anytime."
    },
    {
        "MessageId": 200520490,
        "Flag": 2,
        "Type": 0,
        "NextId": -1,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "ええ、文字通りそうさせていただきますとも。ムフフ",
        "MessageKR": "그 말 후회하시면 안 되니까요\\~?",
        "MessageTW": "之後可不能反悔哦～？",
        "MessageEN": "Famous last words."
