    {
        "MessageId": 101390250,
        "Flag": 2,
        "Type": 3,
        "NextId": 101390260,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "マーフィーの法則のだね",
        "MessageKR": "머피의 법칙, 말이구나.",
        "MessageTW": "",
        "MessageEN": ""
    },
    {
        "MessageId": 101390250,
        "Flag": 2,
        "Type": 3,
        "NextId": 101390260,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "仕事をしていると、よく耳にするよ",
        "MessageKR": "일을 하다 보면 자주 듣곤 하지.",
        "MessageTW": "",
        "MessageEN": ""
