    {
        "MessageId": 101290221,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290230,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "まだ残ってますでしょうか",
        "MessageKR": "아직 남아있나요?",
        "MessageTW": "還在嗎？",
        "MessageEN": "Do you still have it?"
    },
    {
        "MessageId": 101290230,
        "Flag": 2,
        "Type": 3,
        "NextId": 101290240,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "消そうとしていたところだけど",
