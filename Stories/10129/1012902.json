    {
        "MessageId": 101290240,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290241,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "いえ！そうではなく！",
        "MessageKR": "아니, 그게 아닙니다!",
        "MessageTW": "我，我不是那個意思！",
        "MessageEN": "No, that's not it!"
