        "MessageId": 101290340,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290341,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "なるほど",
        "MessageKR": "그렇군요.",
        "MessageTW": "原來如此",
