    {
        "MessageId": 101290290,
        "Flag": 1,
        "Type": 0,
        "NextId": 101290300,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "先生は「同人イベント」というものをご存知ですか？",
        "MessageKR": "혹시 '동인 행사'라는 것을 잘 아시나요?",
        "MessageTW": "請問老師瞭解所謂的「同人活動」嗎？",
        "MessageEN": "Do you know what \"fan conventions\" are?"
    },
    {
        "MessageId": 101290300,
        "Flag": 2,
        "Type": 3,
        "NextId": 101290310,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "専門分野だよ",
        "MessageKR": "거의 박사지 뭐.",
        "MessageTW": "幾乎是博士等級了吧",
        "MessageEN": "I have a PhD in them."
    },
    {
        "MessageId": 101290300,
        "Flag": 2,
        "Type": 3,
        "NextId": 101290310,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "得意分野だよ",
        "MessageKR": "거의 석사지 뭐.",
        "MessageTW": "幾乎是碩士等級了吧",
        "MessageEN": "I have a Master's in them."
    },
    {
        "MessageId": 101290310,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290311,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "ええと、つまり",
        "MessageKR": "네?",
        "MessageTW": "咦？",
        "MessageEN": "What?"
    },
    {
        "MessageId": 101290311,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290320,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "お詳しいのですね",
        "MessageKR": "잘 아신다는 거군요.",
        "MessageTW": "意思是您很熟悉對吧",
        "MessageEN": "So you must be knowledgeable."
    },
    {
        "MessageId": 101290320,
        "Flag": 1,
        "Type": 0,
        "NextId": 101290321,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "自警団に通報が入っていまして",
        "MessageKR": "다름이 아니라 자경단에 제보가 들어왔습니다.",
        "MessageTW": "其實自衛隊收到了檢舉",
        "MessageEN": "Someone sent in a report to the Vigilante Crew."
    },
    {
        "MessageId": 101290321,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290322,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "同人イベントを荒らす不良たちがいると",
        "MessageKR": "불량배들이 행사를 방해해서 곤란하다고 합니다.",
        "MessageTW": "說是有不良分子在妨礙活動，感到相當困擾",
        "MessageEN": "There are thugs causing a scene at a fan convention."
    },
    {
        "MessageId": 101290322,
        "Flag": 2,
        "Type": 0,
        "NextId": 101290330,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "それで是非アドバイスをいただけないかと思い",
        "MessageKR": "그에 관해서 조언을 구하고자 합니다.",
        "MessageTW": "因此想向您請教該如何應對比較適合",
