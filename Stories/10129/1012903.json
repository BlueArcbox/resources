        "MessageTW": "謝謝您。那麼到時候見",
        "MessageEN": "Thank you. I'll see you soon."
    },
    {
        "MessageId": 101280387,
        "Flag": 2,
        "Type": 2,
        "NextId": 101290380,
        "MessageType": "Text",
        "ImagePath": "",
        "MessageJP": "スズミ（マジカル）の絆イベントへ",
        "MessageKR": "스즈미(매지컬)의 인연스토리로",
        "MessageTW": "前往的羈絆劇情",
        "MessageEN": "Go to 's Bond Story"
